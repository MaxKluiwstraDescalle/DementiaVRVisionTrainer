# Ignore Unity specific directories
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
/[Bb]ee/
/[Pp]ackage[Cc]ache/

# Ignore memory captures and recordings
/[Mm]emoryCaptures/
/[Rr]ecordings/

# Ignore asset store tools plugin
/[Aa]ssets/AssetStoreTools*

# Ignore autogenerated Jetbrains Rider plugin
/[Aa]ssets/Plugins/Editor/JetBrains*

# Ignore Visual Studio cache directory
.vs/

# Ignore Gradle cache directory
.gradle/

# Ignore autogenerated VS/MD/Consulo solution and project files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Ignore Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Ignore Unity3D generated file on crash reports
sysinfo.txt

# Ignore builds
*.apk
*.aab
*.unitypackage
*.app

# Ignore Crashlytics generated file
crashlytics-build.properties

# Ignore packed Addressables
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Ignore temporary auto-generated Android Assets
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*

# Ignore VR (Unity XR) specific exclusions
/[Aa]ssets/XR/
/[Aa]ssets/Oculus/
/[Aa]ssets/OpenXR/
/[Aa]ssets/SteamVR/
/[Aa]ssets/WaveVR/
/[Aa]ssets/Plugins/XR/
/[Aa]ssets/Plugins/Oculus/
/[Aa]ssets/Plugins/OpenXR/
/[Aa]ssets/Plugins/SteamVR/
/[Aa]ssets/Plugins/WaveVR/
/[Aa]ssets/Plugins/WindowsMR/
/[Aa]ssets/XRSettings.asset
/[Aa]ssets/OculusSettings.asset
/[Aa]ssets/OpenXRSettings.asset

# Ignore auto-generated XR and platform-specific cache files
[Xx]r[Mm]anagement[Mm]etadata/
[Xx]r[Tt]oolkit[Mm]etadata/
[Xx]r[Pp]latform[Mm]etadata/
[Xx]r[Pp]rovider[Mm]etadata/

# Ignore Unity's Bee and IL2CPP build artifacts
/[Ll]ibrary/Bee/
/[Ll]ibrary/Bee/artifacts/
/[Ll]ibrary/Bee/Android/
/[Ll]ibrary/Bee/Android/Prj/
/[Ll]ibrary/Bee/Android/IL2CPP/
/[Ll]ibrary/Bee/Android/IL2CPP/Gradle/
/[Ll]ibrary/Bee/artifacts/Android/
/[Ll]ibrary/Bee/artifacts/objcopy_*/
/[Ll]ibrary/Bee/artifacts/il2cpp_*/
/[Ll]ibrary/Bee/artifacts/d8kzr/
/[Ll]ibrary/PackageCache/com.unity.burst*/

